@startuml
skinparam backgroundColor white
title Installation Flow

start
:Click Install;
:Detect platform;
:Download ZIP;
:Verify SHA256;
if (Checksum OK?) then (yes)
  if (Is update?) then (yes)
    :Backup current;
  endif
  :Extract to extensions/;
  :Load DSO manifest;
  :Validate registry id/version;
  :Refresh installed cache;
else (no)
  :Error: invalid checksum;
endif
stop
@enduml
